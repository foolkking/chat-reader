APP_NAME=chat-reader

# Replace these values before the first deployment.
POSTGRES_DB=chat_reader
POSTGRES_USER=chat_reader
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Public URL used in generated share links. Do not add a trailing slash.
PUBLIC_WEB_BASE_URL=https://chat.example.com

# Bind 127.0.0.1 when Nginx/Caddy runs on the same server.
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=3000

MAX_IMPORT_FILE_SIZE_MB=50

# Raw import artifacts and temporary .cr exports are stored in Docker volumes.
IMPORT_STORAGE_DIR=/data/imports
EXPORT_STORAGE_DIR=/data/exports

# One worker is the safe default for a small VM. Increase only with enough RAM.
API_WORKERS=1

# Import work is intentionally consumed by one durable PostgreSQL worker.
IMPORT_WORKER_POLL_SECONDS=1
IMPORT_STALE_AFTER_SECONDS=300
