APP_NAME=chat-reader
APP_ENV=development

POSTGRES_DB=chat_reader
POSTGRES_USER=chat_reader
POSTGRES_PASSWORD=chat_reader
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://chat_reader:chat_reader@localhost:5432/chat_reader

API_PORT=8000
WEB_PORT=3000

# Used only by the Next.js server-side rewrite. Browser requests use /api/*.
API_INTERNAL_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
PUBLIC_WEB_BASE_URL=http://localhost:3000

MAX_IMPORT_FILE_SIZE_MB=50
IMPORT_STORAGE_DIR=storage/imports
IMPORT_WORKER_POLL_SECONDS=1
IMPORT_STALE_AFTER_SECONDS=300
